# ============================================================
#  BioCube Backend — Environment Variables
#  Set all of these in Render's Environment section
# ============================================================

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/biocube?retryWrites=true&w=majority

# JWT secret — generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING

# Shared secret with Raspberry Pi bridge
PI_API_SECRET=CHANGE_ME_MATCH_PI_ENV

# Gmail credentials for sending emails
GMAIL_USER=your.gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Frontend URL (for CORS) — your Render frontend URL
FRONTEND_URL=https://biocube-frontend.onrender.com

# Port (Render sets this automatically — leave as is)
PORT=4000
